		 xsi:schemaLocation="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd https://raw.githubusercontent.com/NuGet/NuGet.Client/dev/src/NuGet.Core/NuGet.Packaging/compiler/resources/nuspec.xsd">
	<metadata>
		<id>silnith.tessellation.dynamic</id>
		<version>0.0.1</version>
		<description>A trivial C++ library for tessellating arbitrary polygons into triangle fans.</description>
		<authors>silnith</authors>
		<projectUrl>https://github.com/silnith/example-nuget-native-dynamic</projectUrl>
		<license type="expression">AGPL-3.0-or-later</license>
		<readme>README.md</readme>
		<requireLicenseAcceptance>false</requireLicenseAcceptance>
		<developmentDependency>false</developmentDependency>
		<copyright>silnith.org</copyright>
		<language>en-US</language>
		<tags>native tessellation x86 x64 arm arm64</tags>
		<title>silnith.tessellation.dynamic</title>
		<dependencies>
			<group targetFramework="native" />
		</dependencies>
	</metadata>
